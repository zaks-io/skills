{
  "name": "@zaks-io/skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node scripts/check-skills.mjs",
    "ci:check": "pnpm format:check && pnpm check && pnpm test && pnpm validate:skills && pnpm security:audit && pnpm security:secrets",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "hooks:install": "lefthook install",
    "security:audit": "pnpm audit --audit-level high",
    "security:secrets": "gitleaks detect --no-git --source . --redact --no-banner",
    "security:secrets:history": "gitleaks detect --source . --redact --no-banner",
    "test": "node --test",
    "validate:skills": "npx --yes skills add . --list"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@10.19.0",
  "devDependencies": {
    "lefthook": "^2.1.8",
    "prettier": "^3.8.3"
  }
}
